# =============================================================================
# SWAPI (SinoWhale-api) 生产环境变量模板
# 复制为 .env.production 并填写真实值
# =============================================================================

# ── 部署版本 ──
# 镜像版本号，与 git tag 一致
DEPLOY_VERSION=v0.1.0

# ── PostgreSQL ──
# ⚠️ 生产环境必须修改！建议使用 openssl rand -base64 24 生成
POSTGRES_PASSWORD=change-to-strong-password

# ── Redis ──
# ⚠️ 生产环境必须修改！建议使用 openssl rand -base64 24 生成
REDIS_PASSWORD=change-to-strong-password

# ── Session ──
# ⚠️ 固定 Session 密钥，防止重启后登录失效。建议使用 openssl rand -hex 32 生成
SESSION_SECRET=change-to-64-char-random-string

# ── SinoWhaleX 集成配置 ──
# 总开关：true 时启用方案 C，提取 X-SWX-* Header 并写入日志 other 字段
SWX_HEADER_ENABLED=true
# 严格模式：true 时非法 Header 返回 400；false 时静默忽略并记 SysLog warn
SWX_HEADER_STRICT=false
# 谁可按 swx_user_id 等维度查询日志：admin（默认）/ root / any
SWX_HEADER_LOG_QUERY_ROLE=admin
